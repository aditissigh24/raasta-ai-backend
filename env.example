# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Socket.IO direct connection (AI worker to socket-server)
SOCKET_SERVER_URL=https://your-socket-server.example.com
AI_WORKER_SECRET=your_shared_secret_here

# PostgreSQL direct access (asyncpg DSN format)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Backend Service Configuration
BACKEND_BASE_URL=http://localhost:3000
# Optional: different base URL for /api/coach/active-users (leave empty to use BACKEND_BASE_URL)
BACKEND_BASE_URL2=
BACKEND_API_KEY=sk_live_your_api_key_here

# Redis Configuration (for background task coordination)
REDIS_URL=redis://localhost:6379/0
# AWS ElastiCache example: redis://your-cluster.cache.amazonaws.com:6379
# Redis Cloud example: rediss://default:password@redis-12345.c1.us-east-1.ec2.redns.redis-cloud.com:12345
REDIS_TASK_TTL=300  # Task lock TTL in seconds (default: 300s = 5 min)

# Meta Pixel Configuration (for event tracking)
META_PIXEL_ID=your_meta_pixel_id_here
META_PIXEL_ACCESS_TOKEN=your_meta_pixel_access_token_here
# Optional: Test Event Code for testing in Meta Events Manager
META_PIXEL_TEST_EVENT_CODE=TEST12345

